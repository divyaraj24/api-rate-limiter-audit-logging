# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Free tier limits
RATE_LIMIT_FREE_CAPACITY=30
RATE_LIMIT_FREE_REFILL_TOKENS=30
RATE_LIMIT_FREE_REFILL_SECONDS=60

# Premium tier limits
RATE_LIMIT_PREMIUM_CAPACITY=120
RATE_LIMIT_PREMIUM_REFILL_TOKENS=120
RATE_LIMIT_PREMIUM_REFILL_SECONDS=60

# Audit log location
AUDIT_LOG_FILE=./logs/audit.log
